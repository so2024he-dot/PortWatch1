<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration
  PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-config.dtd">

<!--
    mybatis-config.xml - 최종 수정본

    ✅ 핵심 수정:
      개별 <typeAlias> 등록 → <package> 스캔 방식으로 변경

    [오류 원인 - English]
      Individual typeAlias registration:
        <typeAlias alias="MemberVO" type="com.portwatch.domain.MemberVO"/>
      This requires MemberVO.class to exist at startup.
      If MemberVO.java is missing or in wrong package → ClassNotFoundException.
      → sqlSessionFactory creation fails → HTTP 500 for ALL requests.

    [오류 원인 - 한글]
      개별 typeAlias 등록 방식은 해당 클래스가 클래스패스에 반드시 있어야 함.
      MemberVO.java가 없거나 잘못된 패키지에 있으면 ClassNotFoundException.
      → sqlSessionFactory 생성 실패 → 모든 요청 HTTP 500.

    [해결 - 패키지 스캔]
      <package name="com.portwatch.domain"/> 방식:
      - domain 패키지 전체를 자동 스캔
      - 클래스명이 곧 alias (MemberVO → MemberVO)
      - 새 VO 클래스 추가 시 별도 등록 불필요
-->
<configuration>

    <settings>
        <setting name="cacheEnabled"                     value="true"/>
        <setting name="lazyLoadingEnabled"               value="true"/>
        <setting name="aggressiveLazyLoading"            value="false"/>
        <setting name="multipleResultSetsEnabled"        value="true"/>
        <setting name="useColumnLabel"                   value="true"/>
        <setting name="autoMappingBehavior"              value="PARTIAL"/>
        <setting name="autoMappingUnknownColumnBehavior" value="WARNING"/>
        <setting name="defaultExecutorType"              value="SIMPLE"/>
        <setting name="defaultStatementTimeout"          value="25"/>
        <setting name="callSettersOnNulls"               value="false"/>
        <setting name="logImpl"                          value="SLF4J"/>
        <!-- snake_case → camelCase 자동 변환 (member_id → memberId) -->
        <setting name="mapUnderscoreToCamelCase"         value="true"/>
        <setting name="jdbcTypeForNull"                  value="NULL"/>
    </settings>

    <!--
        ✅ 패키지 스캔 방식 (개별 등록 제거)
        com.portwatch.domain 패키지의 모든 클래스 자동 alias 등록:
        MemberVO, StockVO, PortfolioVO, WatchlistVO, NewsVO 등
    -->
    <typeAliases>
        <package name="com.portwatch.domain"/>
    </typeAliases>

</configuration>
