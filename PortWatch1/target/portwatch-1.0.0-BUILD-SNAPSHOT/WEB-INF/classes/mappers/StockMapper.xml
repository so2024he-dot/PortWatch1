<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
StockMapper.xml - 완전 수정판 (XML 문법 오류 해결)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

✅ 모든 특수문자 인코딩 처리
✅ CDATA 섹션 적용
✅ XML 문법 검증 완료

⚠️ 주의: 기존 StockMapper.xml을 백업 후 교체하세요!
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-->

<mapper namespace="com.portwatch.mapper.StockMapper">
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 주식 코드로 조회 -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <select id="getStockByCode" resultType="com.portwatch.domain.StockVO">
        <![CDATA[
            SELECT 
                stock_code,
                stock_name,
                country,
                market,
                current_price,
                price_change,
                change_rate,
                volume,
                market_cap,
                updated_at,
                created_at
            FROM STOCK
            WHERE stock_code = #{stockCode}
        ]]>
    </select>
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 주식 목록 조회 (필터링) -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <select id="getStockList" resultType="com.portwatch.domain.StockVO">
        <![CDATA[
            SELECT 
                stock_code,
                stock_name,
                country,
                market,
                current_price,
                price_change,
                change_rate,
                volume,
                market_cap,
                updated_at,
                created_at
            FROM STOCK
            WHERE 1=1
        ]]>
        
        <!-- 국가 필터 -->
        <if test="country != null and country != ''">
            AND country = #{country}
        </if>
        
        <!-- 시장 필터 -->
        <if test="market != null and market != ''">
            AND market = #{market}
        </if>
        
        <!-- 검색어 필터 -->
        <if test="searchKeyword != null and searchKeyword != ''">
            <![CDATA[
                AND (
                    stock_code LIKE CONCAT('%', #{searchKeyword}, '%')
                    OR stock_name LIKE CONCAT('%', #{searchKeyword}, '%')
                )
            ]]>
        </if>
        
        <!-- ✅ 가격 범위 필터 (XML 인코딩) -->
        <if test="minPrice != null and minPrice &gt; 0">
            <![CDATA[
                AND current_price >= #{minPrice}
            ]]>
        </if>
        
        <if test="maxPrice != null and maxPrice &gt; 0">
            <![CDATA[
                AND current_price <= #{maxPrice}
            ]]>
        </if>
        
        <![CDATA[
            ORDER BY stock_code
        ]]>
        
        <!-- 페이징 -->
        <if test="limit != null and limit &gt; 0">
            LIMIT #{limit}
        </if>
        
        <if test="offset != null and offset &gt;= 0">
            OFFSET #{offset}
        </if>
    </select>
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 국가별 주식 목록 -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <select id="getStocksByCountry" resultType="com.portwatch.domain.StockVO">
        <![CDATA[
            SELECT 
                stock_code,
                stock_name,
                country,
                market,
                current_price,
                price_change,
                change_rate,
                volume,
                market_cap,
                updated_at,
                created_at
            FROM STOCK
            WHERE country = #{country}
            ORDER BY market, stock_code
        ]]>
    </select>
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 시장별 주식 목록 -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <select id="getStocksByMarket" resultType="com.portwatch.domain.StockVO">
        <![CDATA[
            SELECT 
                stock_code,
                stock_name,
                country,
                market,
                current_price,
                price_change,
                change_rate,
                volume,
                market_cap,
                updated_at,
                created_at
            FROM STOCK
            WHERE market = #{market}
            ORDER BY stock_code
        ]]>
    </select>
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 주식 검색 (종목코드 또는 종목명) -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <select id="searchStocks" resultType="com.portwatch.domain.StockVO">
        <![CDATA[
            SELECT 
                stock_code,
                stock_name,
                country,
                market,
                current_price,
                price_change,
                change_rate,
                volume,
                market_cap,
                updated_at,
                created_at
            FROM STOCK
            WHERE stock_code LIKE CONCAT('%', #{keyword}, '%')
               OR stock_name LIKE CONCAT('%', #{keyword}, '%')
            ORDER BY stock_code
            LIMIT 50
        ]]>
    </select>
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 주식 정보 수정 -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <update id="updateStock">
        UPDATE STOCK
        SET 
            stock_name = #{stockName},
            current_price = #{currentPrice},
            price_change = #{priceChange},
            change_rate = #{changeRate},
            volume = #{volume},
            market_cap = #{marketCap},
            updated_at = NOW()
        WHERE stock_code = #{stockCode}
    </update>
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 주식 등록 -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <insert id="insertStock">
        INSERT INTO STOCK (
            stock_code,
            stock_name,
            country,
            market,
            current_price,
            price_change,
            change_rate,
            volume,
            market_cap,
            created_at,
            updated_at
        ) VALUES (
            #{stockCode},
            #{stockName},
            #{country},
            #{market},
            #{currentPrice},
            #{priceChange},
            #{changeRate},
            #{volume},
            #{marketCap},
            NOW(),
            NOW()
        )
    </insert>
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 주식 삭제 -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <delete id="deleteStock">
        <![CDATA[
            DELETE FROM STOCK
            WHERE stock_code = #{stockCode}
        ]]>
    </delete>
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 전체 주식 수 조회 -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <select id="getStockCount" resultType="int">
        <![CDATA[
            SELECT COUNT(*) FROM STOCK
        ]]>
    </select>
    
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <!-- 시장별 주식 수 조회 -->
    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    
    <select id="getStockCountByMarket" resultType="java.util.HashMap">
        <![CDATA[
            SELECT 
                market,
                COUNT(*) as count
            FROM STOCK
            GROUP BY market
            ORDER BY market
        ]]>
    </select>
    
</mapper>
