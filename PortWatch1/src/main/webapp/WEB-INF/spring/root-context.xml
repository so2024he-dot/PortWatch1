<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context"
    xmlns:mybatis-spring="http://mybatis.org/schema/mybatis-spring"
    xmlns:tx="http://www.springframework.org/schema/tx"
    xmlns:task="http://www.springframework.org/schema/task"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context
        http://www.springframework.org/schema/context/spring-context.xsd
        http://www.springframework.org/schema/tx
        http://www.springframework.org/schema/tx/spring-tx.xsd
        http://www.springframework.org/schema/task
        http://www.springframework.org/schema/task/spring-task.xsd
        http://mybatis.org/schema/mybatis-spring
        http://mybatis.org/schema/mybatis-spring-1.2.xsd">

    <!-- ============================================================
         ✅ 로컬 STS 콘솔 오류 해결 포인트
         ConflictingBeanDefinitionException: 'memberMapper' 충돌

         원인: persistence.MemberMapper(bean="memberMapper") 와
               mapper.MemberMapper(bean="memberMapper") 이름 중복

         해결책:
           1. persistence.MemberMapper.java → 완전 삭제
           2. persistence.MemberDAO.java    → @Mapper("memberDAO") 사용
           3. mybatis-spring:scan → mapper 패키지만 스캔
              (persistence 는 @Mapper 어노테이션으로 자동 등록)

         ※ annotationClass 속성은 mybatis-spring-1.2.xsd 미지원 → 사용 불가
         ============================================================ -->

    <!--
        ══════════════════════════════════════════════════════════════
        HikariCP DataSource - AWS RDS MySQL 8.4.3 연결
        (HikariCP 3.4.5 + MySQL Connector/J 8.x)

        ✅ [2026-04-02 스크린샷 134437 EC2 직접 연결 확인 완료]
           mysql -h portwatch-db-seoul.cpggwqm1goo3.ap-northeast-2.rds.amazonaws.com
           Server version: 8.4.3 Source distribution → 연결 성공!
           portwatch 데이터베이스 존재 확인 ✅

        ⚠️  [이전 버전 jdbcUrl 버그 2종 — 수정 완료]
        ─────────────────────────────────────────────────────────────
        버그1: jdbcUrl 값을 여러 줄로 작성
               XML 속성값에 개행+공백이 그대로 포함됨
               → "jdbc:mysql://...\n   ?useSSL..." 로 파싱
               → MySQL 드라이버 URL 파싱 오류 → Communications link failure
               수정: jdbcUrl 값을 반드시 한 줄로 작성

        버그2: 호스트명 오타 cpggwqmigoo3 (i) → cpggwqm1goo3 (숫자1)
               → 존재하지 않는 호스트 → Connection timed out
               수정: 스크린샷 134437 MySQL 연결 성공 엔드포인트 적용
        ─────────────────────────────────────────────────────────────

        ✅ AWS EC2 setenv.sh (IPv4 강제 — Tomcat 재시작 전 필수):
           sudo tee /opt/tomcat/bin/setenv.sh << 'SETENV'
           #!/bin/bash
           export JAVA_OPTS="-Djava.net.preferIPv4Stack=true -Xms256m -Xmx512m"
           SETENV
           sudo chmod 755 /opt/tomcat/bin/setenv.sh
           cat /opt/tomcat/bin/setenv.sh   ← Permission denied 없어야 함

        ✅ HikariCP 3.4.5 타임아웃 계층:
           connectTimeout=5000  (JDBC TCP 연결 5초)
           < connectionTimeout=30000 (HikariCP 풀 대기 30초)
           규칙: 반드시 connectTimeout < connectionTimeout 이어야 함
        ══════════════════════════════════════════════════════════════
    -->
    <bean id="dataSource" class="com.zaxxer.hikari.HikariDataSource" destroy-method="close">
        <property name="driverClassName" value="com.mysql.cj.jdbc.Driver"/>

        <!--
            ✅ jdbcUrl 작성 규칙: 반드시 한 줄(value="..." 안에 개행 없음)
               개행이 있으면 XML 파서가 공백/줄바꿈을 URL에 포함 → 연결 실패
               ─────────────────────────────────────────────────────
               connectTimeout=10000 : TCP 연결 10초 제한 (JDBC 드라이버 레벨, 5000→10000으로 증가)
               socketTimeout=60000  : 쿼리 실행 60초 제한
               sslMode=DISABLED     : MySQL 8.4 SSL 비활성화
               autoReconnect=true   : 연결 끊김 시 자동 재연결 시도
        -->
        <property name="jdbcUrl" value="jdbc:mysql://portwatch-db-seoul.cpggwqm1goo3.ap-northeast-2.rds.amazonaws.com:3306/portwatch?useSSL=false&amp;sslMode=DISABLED&amp;serverTimezone=Asia/Seoul&amp;characterEncoding=UTF-8&amp;allowPublicKeyRetrieval=true&amp;connectTimeout=10000&amp;socketTimeout=60000&amp;autoReconnect=true"/>

        <property name="username" value="admin"/>
        <property name="password" value="portwatch2026!!abcd"/>

        <!--
            ✅ db.t3.micro: max_connections ≈ 150
               maximumPoolSize=15 (10→15으로 증가):
                 NewsScheduler + StockScheduler + 수동 API 동시 실행 시 풀 경쟁 방지
                 NewsScheduler(한국/미국) + StockScheduler(한국/미국) = 최대 4개 동시
                 + 수동 crawler/korea, /us, update-all = 최대 3개
                 합계 7개 + 여유 8개 = 15개 적합
               minimumIdle=3 (2→3으로 증가): 최소 연결 상시 유지
        -->
        <property name="maximumPoolSize" value="15"/>
        <property name="minimumIdle" value="3"/>

        <!--
            ✅ connectionTimeout=30000 (30초): 풀에서 연결 대기 최대 시간
               반드시 connectTimeout(10000) 보다 커야 함
               connectTimeout=10000 설정으로 TCP 10초 여유 확보
        -->
        <property name="connectionTimeout" value="30000"/>

        <!--
            ✅ AWS NAT Gateway 4분 유휴 타임아웃 대비:
               maxLifetime=180000 (3분): AWS가 끊기기 전에 HikariCP가 먼저 교체
               idleTimeout=120000 (2분): 유휴 연결 조기 반환으로 풀 신선도 유지
               connectionTestQuery=SELECT 1: 연결 사용 전 유효성 확인
        -->
        <property name="idleTimeout" value="120000"/>
        <property name="maxLifetime" value="180000"/>
        <property name="connectionTestQuery" value="SELECT 1"/>

        <!-- ✅ -1: 기동 시 DB 연결 실패해도 Tomcat 기동 허용 (EC2 재시작 안전) -->
        <property name="initializationFailTimeout" value="-1"/>
    </bean>

    <!-- MyBatis SqlSessionFactory -->
    <bean id="sqlSessionFactory" class="org.mybatis.spring.SqlSessionFactoryBean">
        <property name="dataSource" ref="dataSource"/>
        <property name="configLocation" value="classpath:/mybatis-config.xml"/>
        <property name="mapperLocations" value="classpath:/mappers/**/*.xml"/>
        <property name="typeAliasesPackage" value="com.portwatch.domain"/>
    </bean>

    <bean id="sqlSession" class="org.mybatis.spring.SqlSessionTemplate">
        <constructor-arg ref="sqlSessionFactory"/>
    </bean>

    <!-- ✅ 핵심 수정: persistence.MemberMapper 삭제 후 두 패키지 스캔
         각 인터페이스에 @Mapper("고유이름") 으로 충돌 방지 -->
    <mybatis-spring:scan base-package="com.portwatch.mapper,com.portwatch.persistence"/>

    <!-- Transaction Manager -->
    <bean id="transactionManager"
        class="org.springframework.jdbc.datasource.DataSourceTransactionManager">
        <property name="dataSource" ref="dataSource"/>
    </bean>
    <tx:annotation-driven transaction-manager="transactionManager"/>

    <!-- BCrypt Password Encoder -->
    <bean id="passwordEncoder"
        class="org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder"/>

    <!-- ✅ 핵심: @Scheduled 어노테이션 활성화 -->
    <!-- 이 설정이 없으면 @Scheduled가 코드에 있어도 스케줄이 실행되지 않음 -->
    <task:annotation-driven scheduler="taskScheduler"/>

    <!-- 스케줄러 스레드 풀 (최대 5개 동시 실행) -->
    <task:scheduler id="taskScheduler" pool-size="5"/>

    <!-- Service & Scheduler & Config 컴포넌트 스캔 -->
    <context:component-scan base-package="com.portwatch.service"/>
    <context:component-scan base-package="com.portwatch.scheduler"/>
    <context:component-scan base-package="com.portwatch.config"/>
    <context:annotation-config/>

</beans>
